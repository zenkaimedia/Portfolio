# Copy this file to ".env.local" and fill in your values.
# These two are SAFE to expose in the browser by design — security is enforced
# by RLS (see supabase/schema.sql). Committing them is fine, but .env.local is
# gitignored so your real values stay local.
#
# On Vercel: add these in Project Settings -> Environment Variables.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# Your public site URL — used for SEO (canonical URLs, sitemap, OpenGraph).
# Optional: production already defaults to https://portfolio.zenkaimedia.in.
# Leave unset locally (defaults to http://localhost:3000). Only set this to
# override (e.g. a staging domain).
# NEXT_PUBLIC_SITE_URL=https://portfolio.zenkaimedia.in

# ── Admin upload page (/admin) — SERVER-ONLY secrets ────────────────────────
# These have NO NEXT_PUBLIC_ prefix, so they are never sent to the browser.
# Add them in .env.local AND in Vercel -> Project Settings -> Environment Variables.

# Used by the server to write rows + issue signed upload URLs. It BYPASSES RLS,
# so it must stay secret. Find it in Supabase -> Settings -> API -> service_role.
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-SECRET-KEY

# The password you type at /admin/login. Choose a strong one.
ADMIN_PASSWORD=choose-a-strong-password
