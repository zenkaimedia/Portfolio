# Copy this file to ".env.local" and fill in your values.
# These two are SAFE to expose in the browser by design — security is enforced
# by RLS (see supabase/schema.sql). Committing them is fine, but .env.local is
# gitignored so your real values stay local.
#
# On Vercel: add these in Project Settings -> Environment Variables.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# WARNING: never put the service_role key here or anywhere in the repo.
# It bypasses RLS and must stay secret.
